# RAG 系统环境变量配置模板
# 复制为 .env 并修改为实际值

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:9b
EMBEDDING_MODEL=bge-m3

# 服务
HOST=0.0.0.0
PORT=8000

# CORS（逗号分隔多个来源）
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Wav2Lip 远程服务（Windows + RTX 3050）
# WAV2LIP_SERVER_URL=http://100.64.x.x:8001

# 输入限制
MAX_QUESTION_LENGTH=2000
MAX_TTS_LENGTH=5000