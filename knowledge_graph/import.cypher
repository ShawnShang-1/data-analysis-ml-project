// ── 统计验证 ──
MATCH (n) RETURN labels(n)[0] AS 节点类型, count(n) AS 数量 ORDER BY 数量 DESC;
MATCH ()-[r]->() RETURN type(r) AS 关系类型, count(r) AS 数量 ORDER BY 数量 DESC;

// ── 示例查询 ──
// 查询某概念的所有前置知识
MATCH path = (start)-[:PREREQUISITE_OF*]->(end {name: '卷积神经网络'}) RETURN path;

// 查询某章节包含的所有知识点
MATCH (c:Chapter {name: '神经网络'})-[:CONTAINS]->(n) RETURN n;

// 查询可用于分类任务的算法
MATCH (a)-[:USED_IN]->(t:Task {name: '分类'}) RETURN a.name AS 分类算法;

// 查询两个概念之间的最短学习路径
MATCH path = shortestPath((a {name: '机器学习'})-[*]->(b {name: 'Transformer'})) RETURN path;

// 查询与SVM相关的对比算法
MATCH (a {name: 'SVM'})-[:COMPARE_WITH]-(b) RETURN a.name, b.name AS 对比算法;