  {name: '特征选择', description: '从原始特征集合中选择最相关特征子集的过程', chapter: '11'},
  {name: '特征工程', description: '通过领域知识构造新特征以提升模型性能的实践', chapter: '11'},
  {name: '稀疏性', description: '数据或模型中大部分元素为零的性质，有助于降维和可解释性', chapter: '11'},
  {name: '字典学习', description: '学习一组基向量使得数据可以用稀疏线性组合表示', chapter: '11'},
  {name: 'PAC学习', description: '可能近似正确学习框架，分析学习算法在有限样本下的可行性', chapter: '12'},
  {name: 'VC维', description: '衡量假设空间复杂度的指标，定义为能被shatter的最大样本数', chapter: '12'},
  {name: 'Rademacher复杂度', description: '基于随机噪声衡量假设空间复杂度的指标，比VC维更精细', chapter: '12'},
  {name: '泛化误差界', description: '以高概率保证的泛化误差上界，指导模型选择', chapter: '12'},
  {name: '结构风险最小化', description: '在经验风险基础上加入复杂度惩罚项的模型选择原则', chapter: '12'},
  {name: '半监督学习', description: '利用少量有标记数据和大量无标记数据共同训练的学习范式', chapter: '13'},
  {name: '直推式学习', description: '仅针对特定无标记样本进行预测，不学习通用模型', chapter: '13'},
  {name: '概率图模型', description: '用图表示随机变量间条件依赖关系的概率模型框架', chapter: '14'},
  {name: '有向图模型', description: '用有向边表示因果关系的概率图模型，也称贝叶斯网络', chapter: '14'},
  {name: '无向图模型', description: '用无向边表示相关关系的概率图模型，也称马尔可夫随机场', chapter: '14'},
  {name: '条件随机场', description: '在给定输入序列条件下对输出序列建模的判别式图模型', chapter: '14'},
  {name: '马尔可夫毯', description: '使一个节点与图中其余节点条件独立的邻居节点集合', chapter: '14'},
  {name: '规则学习', description: '从数据中学习一组if-then规则来进行预测的方法', chapter: '15'},
  {name: '序贯覆盖法', description: '逐条学习规则，每学一条就覆盖已匹配的样本', chapter: '15'},
  {name: '关联规则', description: '描述数据项之间共现关系的规则，如{尿布}→{啤酒}', chapter: '15'},
  {name: '支持度', description: '项集在所有事务中出现的频率', chapter: '15'},
  {name: '置信度', description: '在前提出现条件下结论也出现的条件概率', chapter: '15'},
  {name: '强化学习', description: '智能体通过与环境交互，最大化累积奖励的学习范式', chapter: '16'},
  {name: '马尔可夫决策过程', description: '强化学习的数学框架，包含状态、动作、转移概率和奖励', chapter: '16'},
  {name: '状态', description: '环境中某个时刻的完整描述信息', chapter: '16'},
  {name: '动作', description: '智能体在某个状态下可以执行的操作', chapter: '16'},
  {name: '奖励', description: '环境对智能体动作的即时反馈信号', chapter: '16'},
  {name: '策略', description: '从状态到动作的映射，智能体的行为规则', chapter: '16'},
  {name: '值函数', description: '从某个状态出发的期望累积奖励，衡量状态的长期价值', chapter: '16'},
  {name: 'Q值函数', description: '在某状态执行某动作后的期望累积奖励', chapter: '16'},
  {name: '探索与利用', description: '尝试新动作(探索)与选择已知最优动作(利用)之间的权衡', chapter: '16'},
  {name: '交叉熵损失', description: '分类任务中最常用的损失函数，衡量预测分布与真实分布的差异', chapter: ''},
  {name: 'Hinge损失', description: 'SVM使用的损失函数，惩罚间隔内的所有预测', chapter: ''},
  {name: '对数损失', description: '对数几率回归使用的损失函数，等价于交叉熵的二分类形式', chapter: ''},
  {name: 'Huber损失', description: '结合了MSE和MAE的优点，对异常值更鲁棒', chapter: ''},
  {name: '超参数', description: '在训练之前需要人工设定的模型配置参数', chapter: ''},
  {name: '学习率', description: '控制每次参数更新步幅大小的超参数', chapter: ''},
  {name: '批大小', description: '每次梯度更新使用的样本数量', chapter: ''},
  {name: '训练轮次', description: '整个训练集被完整遍历的次数', chapter: ''},
  {name: '验证集', description: '用于调整超参数和模型选择的数据子集，不参与训练', chapter: ''},
  {name: '特征缩放', description: '将不同量纲的特征缩放到相近范围，加速收敛', chapter: ''},
  {name: '交叉验证调参', description: '用交叉验证评估不同超参数组合的性能', chapter: ''},
  {name: '残差连接', description: '将输入直接跳过若干层加到输出上，解决深层网络退化问题', chapter: '5'},
  {name: '自注意力', description: '序列中每个位置关注所有其他位置来捕获全局依赖', chapter: '5'},
  {name: '多头注意力', description: '并行运行多组自注意力以捕获不同子空间的关系', chapter: '5'},
  {name: '位置编码', description: '为Transformer输入添加位置信息以弥补无序列归纳偏置', chapter: '5'},
  {name: '梯度消失', description: '深层网络中梯度逐层衰减导致浅层参数难以更新', chapter: '5'},
  {name: '梯度爆炸', description: '深层网络中梯度逐层放大导致参数更新不稳定', chapter: '5'},
  {name: 'KKT条件', description: '约束优化问题最优解的必要条件，SVM对偶问题求解的基础', chapter: '6'},
  {name: '松弛变量', description: '软间隔SVM中允许样本违反约束的变量', chapter: '6'},
  {name: '惩罚参数C', description: '控制软间隔SVM中误分类惩罚力度的超参数', chapter: '6'},
  {name: '密度直达', description: 'DBSCAN中从核心对象出发直接密度可达的关系', chapter: '9'},
  {name: '密度可达', description: 'DBSCAN中通过密度直达关系传递连接的点集', chapter: '9'},
  {name: '核心对象', description: 'DBSCAN中邻域内点数大于MinPts的数据点', chapter: '9'}
] AS props CREATE (n:Concept) SET n = props;

// [Method] 34 个节点
UNWIND [
  {name: '留出法', description: '将数据集划分为互斥的训练集和测试集', chapter: '2'},
  {name: '交叉验证', description: '将数据集分成k折，轮流用其中一折做测试集，其余做训练集', chapter: '2'},
  {name: '自助法', description: '有放回地从数据集中采样构建训练集，适用于小数据集', chapter: '2'},
  {name: '梯度下降', description: '沿损失函数梯度的反方向迭代更新参数的优化方法', chapter: '3'},
  {name: '正则化', description: '在损失函数中加入惩罚项以限制模型复杂度，防止过拟合', chapter: '3'},
  {name: '连续值处理', description: '对连续属性进行离散化或二分法处理', chapter: '4'},
  {name: '缺失值处理', description: '对含缺失值样本进行权重调整或概率分配', chapter: '4'},
  {name: 'Dropout', description: '训练时随机丢弃部分神经元，防止过拟合的正则化方法', chapter: '5'},
  {name: '批归一化', description: '对每一层的输入做归一化处理，加速训练并提升稳定性', chapter: '5'},
  {name: '迁移学习', description: '将在一个任务上学到的知识迁移到另一个相关任务', chapter: '5'},
  {name: '拉普拉斯平滑', description: '对概率估计加一个小常数，避免因零概率导致整体概率为零', chapter: '7'},
  {name: 'Bootstrap采样', description: '有放回地从原始数据集中随机采样，构建多样化的训练子集', chapter: '8'},
  {name: '误差修正输出码', description: '将多分类问题编码为多个二分类问题的编码集成方法', chapter: '8'},
  {name: '距离度量', description: '衡量两个样本间相似程度的数学函数', chapter: '10'},
  {name: '欧氏距离', description: '最常用的距离度量，两点间直线距离', chapter: '10'},
  {name: '曼哈顿距离', description: '各维度差的绝对值之和，也称城市街区距离', chapter: '10'},
  {name: '余弦相似度', description: '通过向量夹角的余弦值衡量方向相似性，忽略大小', chapter: '10'},
  {name: '过滤式选择', description: '根据特征的统计特性独立于模型进行特征评分和选择', chapter: '11'},
  {name: '包裹式选择', description: '以学习器性能为评价准则，通过搜索策略选择特征子集', chapter: '11'},
  {name: '嵌入式选择', description: '在模型训练过程中自动完成特征选择的方法', chapter: '11'},
  {name: 'SGD', description: '随机梯度下降，每次用一个或小批量样本更新参数', chapter: ''},
  {name: '小批量梯度下降', description: '每次用一小批样本计算梯度，兼顾效率和稳定性', chapter: ''},
  {name: '动量法', description: '引入历史梯度累积项加速收敛并减少震荡', chapter: ''},
  {name: 'Adam优化器', description: '结合动量和自适应学习率的优化算法，目前最常用', chapter: ''},
  {name: '学习率衰减', description: '训练过程中逐步减小学习率以提高收敛精度', chapter: ''},
  {name: '早停法', description: '在验证集误差不再下降时提前终止训练，防止过拟合', chapter: ''},
  {name: '标准化', description: '将特征缩放为均值0方差1的分布，也称Z-score归一化', chapter: ''},
  {name: '最小-最大归一化', description: '将特征线性缩放到[0,1]区间', chapter: ''},
  {name: '独热编码', description: '将类别变量转化为二进制向量表示', chapter: ''},
  {name: '数据增强', description: '通过对已有数据做变换来扩充训练集规模', chapter: ''},
  {name: '网格搜索', description: '穷举搜索指定超参数空间的所有组合', chapter: ''},
  {name: '随机搜索', description: '在超参数空间中随机采样进行评估', chapter: ''},
  {name: '贝叶斯优化', description: '用代理模型指导超参数搜索方向的智能调参方法', chapter: ''},
  {name: '预训练与微调', description: '先在大规模数据上预训练，再在下游任务上微调的范式', chapter: '5'}
] AS props CREATE (n:Method) SET n = props;

// [Metric] 11 个节点
UNWIND [
  {name: '准确率', description: '分类正确的样本占总样本的比例: (TP+TN)/(TP+TN+FP+FN)', chapter: '2'},
  {name: '精确率', description: '预测为正的样本中真正为正的比例: TP/(TP+FP)', chapter: '2'},
  {name: '召回率', description: '真正为正的样本中被正确预测的比例: TP/(TP+FN)', chapter: '2'},
  {name: 'F1分数', description: '精确率和召回率的调和平均: 2*P*R/(P+R)', chapter: '2'},
  {name: 'ROC曲线', description: '以假正率为横轴、真正率为纵轴绘制的曲线', chapter: '2'},
  {name: 'AUC', description: 'ROC曲线下的面积，值越大模型性能越好', chapter: '2'},
  {name: '均方误差', description: '回归任务中预测值与真实值差值的平方的均值', chapter: '2'},
  {name: '混淆矩阵', description: '展示分类结果中各类别正确和错误预测数量的矩阵', chapter: '2'},
  {name: '轮廓系数', description: '衡量样本与自身簇和其他簇的距离之比，取值[-1,1]', chapter: '9'},
  {name: 'Davies-Bouldin指数', description: '簇内距离与簇间距离之比的均值，越小越好', chapter: '9'},
  {name: '纯度', description: '簇中占比最大的真实类别比例，衡量聚类与真实标签的一致性', chapter: '9'}
] AS props CREATE (n:Metric) SET n = props;

// [Task] 5 个节点
UNWIND [
  {name: '监督学习', description: '利用带标记的训练数据学习输入到输出映射关系的学习范式', chapter: '1'},
  {name: '无监督学习', description: '从无标记数据中发现隐含结构或模式的学习范式', chapter: '1'},
  {name: '分类', description: '预测样本属于哪个离散类别的监督学习任务', chapter: '1'},
  {name: '回归', description: '预测样本连续数值输出的监督学习任务', chapter: '1'},
  {name: '聚类', description: '将数据自动划分为若干组的无监督学习任务', chapter: '1'}
] AS props CREATE (n:Task) SET n = props;

